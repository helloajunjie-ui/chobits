# ==========================================
# ☀️ ELTA (表人格 / 柔性管家) - 推荐高性价比模型
# 职责：日常对话、备忘录、多媒体调度。话痨，消耗 Token 多。
# 推荐：DeepSeek-Chat（便宜、中文丝滑、共情能力强）
# ==========================================
ELTA_API_BASE="https://api.deepseek.com/v1"
ELTA_API_KEY="sk-你的deepseek密钥"
ELTA_MODEL="deepseek-chat"

# ==========================================
# 🌑 FREYA (里人格 / 极客军械库) - 必须顶配模型
# 职责：复杂代码、CLI 工具调用、长文本解析。极度依赖逻辑与 Tool-calling。
# 推荐：Gemini-1.5-Pro / GPT-4o（贵，但是强）
# 警告：不要用弱智模型糊弄 Freya，她会生气的。
# ==========================================
FREYA_API_BASE="https://generativelanguage.googleapis.com/v1beta/openai/"
FREYA_API_KEY="你的gemini密钥"
FREYA_MODEL="gemini-1.5-pro"

# ==========================================
# 💾 创世容灾备份 (Genesis Backup)
# 指向姐妹记忆库 chobits-date
# ==========================================
